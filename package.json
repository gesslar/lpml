{
  "name": "lpml",
  "displayName": "LPML stands for LPC Markup Language",
  "description": "Syntax highlighting for LPML (LPC Markup Language) files.",
  "version": "0.1.3",
  "engines": {
    "vscode": ">=1.104.0",
    "node": ">=24.11.0"
  },
  "license": "0BSD",
  "publisher": "gesslar",
  "repository": {
    "url": "https://github.com/gesslar/lpml"
  },
  "icon": "./assets/l-512.png",
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "pr": "gt submit -p --ai",
    "prepackage": "node scripts/assure-clean-vsix-directory.mjs",
    "package": "npx @vscode/vsce package --no-dependencies --skip-license -o vsix/",
    "premarket": "npm run package",
    "publish:vsce": "npm run premarket && npx @vscode/vsce publish --packagePath vsix/*.vsix --pat $VSX_MARKETPLACE_ACCESS_TOKEN",
    "publish:ovsx": "npm run premarket && npx ovsx publish --packagePath vsix/*.vsix --pat $OVSX_ACCESS_TOKEN",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "contributes": {
    "languages": [
      {
        "id": "lpml",
        "aliases": [
          "LPML",
          "lpml"
        ],
        "extensions": [
          ".lpml"
        ],
        "configuration": "./language-configuration.lpml.json"
      }
    ],
    "grammars": [
      {
        "language": "lpml",
        "scopeName": "source.lpml",
        "path": "./syntaxes/lpml.tmLanguage.json"
      }
    ]
  }
}
