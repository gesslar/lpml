{
	"scopeName": "source.lpml",
	"fileTypes": [
		"lpml"
	],
	"name": "LPML",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#value"
		}
	],
	"repository": {
		"array": {
			"begin": "\\[",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.array.begin.lpml punctuation.definition.array.begin.json.five"
				}
			},
			"end": "\\]",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.array.end.lpml punctuation.definition.array.end.json.five"
				}
			},
			"name": "meta.structure.array.lpml meta.structure.array.json.five",
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"include": "#value"
				},
				{
					"match": ",",
					"name": "punctuation.separator.array.lpml punctuation.separator.array.json.five"
				},
				{
					"match": "[^\\s\\]]",
					"name": "invalid.illegal.expected-array-separator.lpml invalid.illegal.expected-array-separator.json.five"
				}
			]
		},
		"constant": {
			"match": "\\b(?:true|false|null|undefined|Infinity|NaN|MAX_INT|MAX_FLOAT)\\b",
			"name": "constant.language.lpml constant.language.json.five"
		},
		"infinity": {
			"match": "[+-]?\\b(?:Infinity|NaN|MAX_INT|MAX_FLOAT)\\b",
			"name": "constant.language.lpml constant.language.json.five"
		},
		"number": {
			"patterns": [
				{
					"comment": "handles hexadecimal numbers",
					"match": "[+-]?(0[xX])[0-9a-fA-F]+",
					"name": "constant.numeric.hex.lpml constant.numeric.hex.json.five"
				},
				{
					"comment": "handles octal numbers",
					"match": "[+-]?(0[oO])[0-7]+",
					"name": "constant.numeric.oct.lpml constant.numeric.oct.json.five"
				},
				{
					"comment": "handles binary numbers",
					"match": "[+-]?(0[bB])[01]+",
					"name": "constant.numeric.bin.lpml constant.numeric.bin.json.five"
				},
				{
					"comment": "handles integer and decimal numbers",
					"match": "[+-]?(?:\\.\\d+|(?=[1-9]|0(?!\\d))\\d+(?:\\.\\d*)?)(?:[eE][+-]?\\d+)?",
					"name": "constant.numeric.dec.lpml constant.numeric.dec.json.five"
				}
			]
		},
		"object": {
			"begin": "\\{",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.dictionary.begin.lpml punctuation.definition.dictionary.begin.json.five"
				}
			},
			"comment": "a lpml object",
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.dictionary.end.lpml punctuation.definition.dictionary.end.json.five"
				}
			},
			"name": "meta.structure.dictionary.lpml meta.structure.dictionary.json.five",
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"comment": "the lpml object key",
					"include": "#key"
				},
				{
					"begin": ":",
					"beginCaptures": {
						"0": {
							"name": "punctuation.separator.dictionary.key-value.lpml punctuation.separator.dictionary.key-value.json.five"
						}
					},
					"end": "(,)|(?=\\})",
					"endCaptures": {
						"1": {
							"name": "punctuation.separator.dictionary.pair.lpml punctuation.separator.dictionary.pair.json.five"
						}
					},
					"name": "meta.structure.dictionary.value.lpml meta.structure.dictionary.value.json.five",
					"patterns": [
						{
							"comment": "the lpml object value",
							"include": "#value"
						},
						{
							"include": "#comments"
						},
						{
							"match": "[^\\s,]",
							"name": "invalid.illegal.expected-dictionary-separator.lpml invalid.illegal.expected-dictionary-separator.json.five"
						}
					]
				},
				{
					"match": "[^\\s\\}]",
					"name": "invalid.illegal.expected-dictionary-separator.lpml invalid.illegal.expected-dictionary-separator.json.five"
				}
			]
		},
		"stringInclude": {
			"comment": "LPML file include syntax: \"#/path/to/file\"",
			"begin": "(['\"])(?=#)",
			"beginCaptures": {
				"1": {
					"name": "punctuation.definition.string.begin.lpml punctuation.definition.string.begin.json.five"
				}
			},
			"end": "\\1",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.end.lpml punctuation.definition.string.end.json.five"
				}
			},
			"name": "string.quoted.include.lpml keyword.control.import.lpml",
			"patterns": [
				{
					"match": "#[^'\"]+",
					"name": "entity.name.import.lpml"
				}
			]
		},
		"stringSingle": {
			"begin": "[']",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.string.begin.lpml punctuation.definition.string.begin.json.five"
				}
			},
			"end": "[']",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.end.lpml punctuation.definition.string.end.json.five"
				}
			},
			"name": "string.quoted.single.lpml string.quoted.single.json.five",
			"patterns": [
				{
					"comment": "LPML escaped include: \\#general becomes #general",
					"match": "\\\\#",
					"name": "constant.character.escape.lpml constant.character.escape.json.five"
				},
				{
					"match": "(?x:                # turn on extended mode\n                     \\\\                # a literal backslash\n                     (?:               # ...followed by...\n                       [\"\\\\/bfnrt]     # one of these characters\n                       |               # ...or...\n                       u               # a u\n                       [0-9a-fA-F]{4}  # and four hex digits\n                     )\n                   )",
					"name": "constant.character.escape.lpml constant.character.escape.json.five"
				},
				{
					"match": "\\\\.",
					"name": "invalid.illegal.unrecognized-string-escape.lpml invalid.illegal.unrecognized-string-escape.json.five"
				}
			]
		},
		"stringDouble": {
			"begin": "[\"]",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.string.begin.lpml punctuation.definition.string.begin.json.five"
				}
			},
			"end": "[\"]",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.end.lpml punctuation.definition.string.end.json.five"
				}
			},
			"name": "string.quoted.double.lpml string.quoted.double.json.five",
			"patterns": [
				{
					"comment": "LPML escaped include: \\#general becomes #general",
					"match": "\\\\#",
					"name": "constant.character.escape.lpml constant.character.escape.json.five"
				},
				{
					"match": "(?x:                # turn on extended mode\n                     \\\\                # a literal backslash\n                     (?:               # ...followed by...\n                       [\"\\\\/bfnrt]     # one of these characters\n                       |               # ...or...\n                       u               # a u\n                       [0-9a-fA-F]{4}  # and four hex digits\n                     )\n                   )",
					"name": "constant.character.escape.lpml constant.character.escape.json.five"
				},
				{
					"match": "\\\\.",
					"name": "invalid.illegal.unrecognized-string-escape.lpml invalid.illegal.unrecognized-string-escape.json.five"
				}
			]
		},
		"key": {
			"patterns": [
				{
					"begin": "[']",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.lpml punctuation.definition.string.begin.json.five"
						}
					},
					"end": "[']",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.lpml punctuation.definition.string.end.json.five"
						}
					},
					"name": "string.quoted.single.lpml string.quoted.single.json.five support.type.property-name.lpml support.type.property-name.json.five",
					"patterns": [
						{
							"match": "(?x:                # turn on extended mode\n                     \\\\                # a literal backslash\n                     (?:               # ...followed by...\n                       [\"\\\\/bfnrt]     # one of these characters\n                       |               # ...or...\n                       u               # a u\n                       [0-9a-fA-F]{4}  # and four hex digits\n                     )\n                   )",
							"name": "constant.character.escape.lpml constant.character.escape.json.five"
						},
						{
							"match": "\\\\.",
							"name": "invalid.illegal.unrecognized-string-escape.lpml invalid.illegal.unrecognized-string-escape.json.five"
						}
					]
				},
				{
					"begin": "[\"]",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.lpml punctuation.definition.string.begin.json.five"
						}
					},
					"end": "[\"]",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.lpml punctuation.definition.string.end.json.five"
						}
					},
					"name": "string.quoted.double.lpml string.quoted.double.json.five support.type.property-name.lpml support.type.property-name.json.five",
					"patterns": [
						{
							"match": "(?x:                # turn on extended mode\n                     \\\\                # a literal backslash\n                     (?:               # ...followed by...\n                       [\"\\\\/bfnrt]     # one of these characters\n                       |               # ...or...\n                       u               # a u\n                       [0-9a-fA-F]{4}  # and four hex digits\n                     )\n                   )",
							"name": "constant.character.escape.lpml constant.character.escape.json.five"
						},
						{
							"match": "\\\\.",
							"name": "invalid.illegal.unrecognized-string-escape.lpml invalid.illegal.unrecognized-string-escape.json.five"
						}
					]
				},
				{
					"comment": "LPML spacey key (YAML-style): an unquoted key is any run of characters up to the first ':' separator, trimmed — spaces, hyphens, dots, and UTF-8 letters are all valid. Quote the key if it must contain a literal ':'.",
					"match": "[^\\s:][^:\\n]*?(?=\\s*:)",
					"name": "string.key.lpml string.key.json.five support.type.property-name.lpml support.type.property-name.json.five"
				}
			]
		},
		"value": {
			"comment": "the 'value' diagram at http://json.org",
			"patterns": [
				{
					"include": "#constant"
				},
				{
					"include": "#infinity"
				},
				{
					"include": "#number"
				},
				{
					"include": "#stringInclude"
				},
				{
					"include": "#stringSingle"
				},
				{
					"include": "#stringDouble"
				},
				{
					"include": "#array"
				},
				{
					"include": "#object"
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"match": "/{2}.*",
					"name": "comment.single.lpml comment.single.json.five"
				},
				{
					"begin": "/\\*\\*(?!/)",
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.lpml punctuation.definition.comment.json.five"
						}
					},
					"end": "\\*/",
					"name": "comment.block.documentation.lpml comment.block.documentation.json.five"
				},
				{
					"begin": "/\\*",
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.lpml punctuation.definition.comment.json.five"
						}
					},
					"end": "\\*/",
					"name": "comment.block.lpml comment.block.json.five"
				}
			]
		}
	}
}
